\n    }\n\n    function delta(int256 a, int256 b) internal pure returns (uint256) {\n        // a and b are of the same sign\n        // this works thanks to two's complement, the left-most bit is the sign bit\n        if ((a ^ b) > -1) {\n            return delta(abs(a), abs(b));\n        }\n\n        // a and b are of opposite signs\n        return abs(a) + abs(b);\n    }\n\n    function percentDelta(uint256 a, uint256 b) internal pure returns (uint256) {\n        uint256 absDelta = delta(a, b);\n\n        return absDelta * 1e18 / b;\n    }\n\n    function percentDelta(int256 a, int256 b) internal pure returns (uint256) {\n        uint256 absDelta = delta(a, b);\n        uint256 absB = abs(b);\n\n        return absDelta * 1e18 / absB;\n    }\n}\n","license":"MIT"}},"version":1},"storageLayout":{"storage":[],"types":{}},"userdoc":{"version":1,"kind":"user"},"devdoc":{"version":1,"kind":"dev"},"ast":{"absolutePath":"lib/forge-std/src/StdMath.sol","id":18573,"exportedSymbols":{"stdMath":[18572]},"nodeType":"SourceUnit","src":"32:1328:87","nodes":[{"id":18432,"nodeType":"PragmaDirective","src":"32:31:87","nodes":[],"literals":["solidity",">=","0.6",".2","<","0.9",".0"]},{"id":18572,"nodeType":"ContractDefinition","src":"65:1294:87","nodes":[{"id":18436,"nodeType":"VariableDeclaration","src":"87:115:87","nodes":[],"constant":true,"mutability":"constant","name":"INT256_MIN","nameLocation":"111:10:87","scope":18572,"stateVariable":true,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_int256","typeString":"int256"},"typeName":{"id":18433,"name":"int256","nodeType":"ElementaryTypeName","src":"87:6:87","typeDescriptions":{"typeIdentifier":"t_int256","typeString":"int256"}},"value":{"id":18435,"isConstant":false,"isLValue":false,"isPure":true,"lValueRequested":false,"nodeType":"UnaryOperation","operator":"-","prefix":true,"src":"124:78:87","subExpression":{"hexValue":"35373839363034343631383635383039373731313738353439323530343334333935333932363633343939323