# Sepolia runtime environment for a deployed Thanos L2 chain.
# Copy to `.env.sepolia.thanos` and fill in RPC URLs/private keys.

# L1 endpoints
L1_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
L1_BEACON_URL=https://ethereum-sepolia-beacon-api.publicnode.com
L1_CHAIN_ID=11155111

# L2 chain (deployed by one-click deployment flow)
L2_CHAIN_ID=7071751

# Images
IMAGE_TAG=latest
L2_IMAGE=tokamaknetwork/thanos-op-geth:nightly

# Local ports
L2_HTTP_PORT=9545
L2_WS_PORT=9546
L2_AUTH_PORT=8551
L2_METRICS_PORT=8060

OP_NODE_RPC_PORT=7545
OP_NODE_METRICS_PORT=7300
OP_NODE_PPROF_PORT=6060

OP_BATCHER_RPC_PORT=8548
OP_BATCHER_METRICS_PORT=7301
OP_BATCHER_PPROF_PORT=6061

OP_PROPOSER_RPC_PORT=8560
OP_PROPOSER_METRICS_PORT=7302
OP_PROPOSER_PPROF_PORT=6062

# Runtime artifacts
GENESIS_L2_PATH=../.deployer/genesis-l2.json
ROLLUP_CONFIG_PATH=../.deployer/rollup.json
JWT_SECRET_PATH=./test-jwt-secret.txt
CANNON_PRESTATE_PATH=../op-program/bin/prestate.json

# Operational settings
GETH_VERBOSITY=3
SEQUENCER_L1_CONFS=4
VERIFIER_L1_CONFS=4

BATCHER_POLL_INTERVAL=6s
BATCHER_SUB_SAFETY_MARGIN=6
BATCHER_NUM_CONFIRMATIONS=1
BATCHER_SAFE_ABORT_NONCE_TOO_LOW_COUNT=3
BATCHER_RESUBMISSION_TIMEOUT=30s
BATCHER_MAX_CHANNEL_DURATION=300
BATCHER_TARGET_NUM_FRAMES=1
BATCHER_APPROX_COMPR_RATIO=0.4
OP_BATCHER_BATCH_TYPE=0

PROPOSER_POLL_INTERVAL=12s
PROPOSER_ALLOW_NON_FINALIZED=false
PROPOSAL_INTERVAL=10m
DG_TYPE=0

CHALLENGER_GAME_TYPES=cannon
CHALLENGER_NUM_CONFIRMATIONS=1

# Private keys (must match role addresses configured in intent/state)
BATCHER_PRIVATE_KEY=0xYOUR_BATCHER_PRIVATE_KEY
PROPOSER_PRIVATE_KEY=0xYOUR_PROPOSER_PRIVATE_KEY
CHALLENGER_PRIVATE_KEY=0xYOUR_CHALLENGER_PRIVATE_KEY

# Deployed contracts from one-click deployment output
DGF_ADDRESS=0x902e546704936789ff8a4f1622896be04a6ba339
SYSTEM_CONFIG_PROXY=0x5165ac6bf4732cc2f611cac7c5d1f960475e4461
OPTIMISM_PORTAL_PROXY=0x4a4448d90a700ca22f84b35e1a1ea1d598b09aaf
L1_STANDARD_BRIDGE_PROXY=0xd273b608efd41c0299d8561f3002e5ef4f406e23
L1_XDM_PROXY=0x011a70af577e8e436c193d3bcb2f178b11912d8e
MINTABLE_ERC20_FACTORY_PROXY=0x88884da4046163e1340cb9dc474eb8fe98dab236

# Expected role addresses from applied intent (for key/address sanity checks)
EXPECTED_BATCHER_ADDRESS=0xc9402d34cd9b375d1ed19c92c9ac325738301fa5
EXPECTED_PROPOSER_ADDRESS=0xc9402d34cd9b375d1ed19c92c9ac325738301fa5
EXPECTED_CHALLENGER_ADDRESS=0xfd1d2e729ae8eee2e146c033bf4400fe75284301
