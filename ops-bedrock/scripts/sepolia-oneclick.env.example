# One-click Sepolia deployment + runtime configuration
# Usage:
#   cp ops-bedrock/scripts/sepolia-oneclick.env.example .env.sepolia.oneclick
#   ./ops-bedrock/scripts/sepolia-oneclick.sh --env-file .env.sepolia.oneclick

# -----------------------------------------------------------------------------
# Required: L1 endpoints and private keys
# -----------------------------------------------------------------------------
L1_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
L1_BEACON_URL=https://ethereum-sepolia-beacon-api.publicnode.com

DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
BATCHER_PRIVATE_KEY=0xYOUR_BATCHER_PRIVATE_KEY
PROPOSER_PRIVATE_KEY=0xYOUR_PROPOSER_PRIVATE_KEY
CHALLENGER_PRIVATE_KEY=0xYOUR_CHALLENGER_PRIVATE_KEY

# -----------------------------------------------------------------------------
# Tokamak Deploy.s.sol behavior
# -----------------------------------------------------------------------------
DEPLOYER_L1_CHAIN_ID=11155111
# Optional. If set, overrides l2ChainID in deploy config template.
# DEPLOYER_L2_CHAIN_ID=111551119090

# Absolute path or repo-relative path are both accepted.
DEPLOYER_WORKDIR=.deployer

# Tokamak contracts package and deploy config template.
TOKAMAK_CONTRACTS_DIR=packages/tokamak/contracts-bedrock
TOKAMAK_DEPLOY_CONFIG_TEMPLATE=packages/tokamak/contracts-bedrock/deploy-config/thanos-sepolia.json

# Generated files. Keep defaults unless you need a custom path.
TOKAMAK_DEPLOY_CONFIG_GENERATED=.deployer/deploy-config.generated.json
TOKAMAK_DEPLOYMENT_OUTFILE=.deployer/l1-deployments.json

# true => skip L1 deployment (requires existing TOKAMAK_DEPLOYMENT_OUTFILE)
TOKAMAK_SKIP_L1_DEPLOY=false
# true => run forge with --resume
TOKAMAK_DEPLOY_RESUME=false
# true => skip genesis/rollup generation (requires existing files)
TOKAMAK_SKIP_GENESIS=false

# Deploy.s.sol tx options
TOKAMAK_DEPLOY_SLOW=true
TOKAMAK_DEPLOY_LEGACY=true
TOKAMAK_DEPLOY_NON_INTERACTIVE=true
# TOKAMAK_DEPLOY_GAS_PRICE=20000000000
# TOKAMAK_IMPL_SALT=

# op-node genesis runner: docker|local
TOKAMAK_OP_NODE_RUNNER=docker
TOKAMAK_OP_NODE_IMAGE=tokamaknetwork/thanos-op-node:latest
# TOKAMAK_OP_NODE_LOCAL_BIN=/absolute/path/to/op-node

# -----------------------------------------------------------------------------
# Runtime compose behavior
# -----------------------------------------------------------------------------
RUNTIME_COMPOSE_FILE=ops-bedrock/docker-compose.sepolia.thanos.yml
RUNTIME_ENV_OUT=ops-bedrock/.env.sepolia.thanos.generated
RUNTIME_UP=true
RUNTIME_DOWN_FIRST=false

# Runtime artifact paths (relative to ops-bedrock)
RUNTIME_GENESIS_PATH_REL=../.deployer/genesis-l2.json
RUNTIME_ROLLUP_PATH_REL=../.deployer/rollup.json
JWT_SECRET_PATH=./test-jwt-secret.txt
CANNON_PRESTATE_PATH=../op-program/bin/prestate.json

# -----------------------------------------------------------------------------
# Runtime images/ports
# -----------------------------------------------------------------------------
IMAGE_TAG=latest
L2_IMAGE=tokamaknetwork/thanos-op-geth:nightly

L2_HTTP_PORT=9545
L2_WS_PORT=9546
L2_AUTH_PORT=8551
L2_METRICS_PORT=8060
OP_NODE_RPC_PORT=7545
OP_NODE_METRICS_PORT=7300
OP_NODE_PPROF_PORT=6060
OP_BATCHER_RPC_PORT=8548
OP_BATCHER_METRICS_PORT=7301
OP_BATCHER_PPROF_PORT=6061
OP_PROPOSER_RPC_PORT=8560
OP_PROPOSER_METRICS_PORT=7302
OP_PROPOSER_PPROF_PORT=6062

# -----------------------------------------------------------------------------
# Runtime tuning
# -----------------------------------------------------------------------------
GETH_VERBOSITY=3
SEQUENCER_L1_CONFS=4
VERIFIER_L1_CONFS=4

BATCHER_POLL_INTERVAL=6s
BATCHER_SUB_SAFETY_MARGIN=6
BATCHER_NUM_CONFIRMATIONS=1
BATCHER_SAFE_ABORT_NONCE_TOO_LOW_COUNT=3
BATCHER_RESUBMISSION_TIMEOUT=30s
BATCHER_MAX_CHANNEL_DURATION=300
BATCHER_TARGET_NUM_FRAMES=1
BATCHER_APPROX_COMPR_RATIO=0.4
OP_BATCHER_BATCH_TYPE=0

PROPOSER_POLL_INTERVAL=12s
PROPOSER_ALLOW_NON_FINALIZED=false
PROPOSAL_INTERVAL=10m
DG_TYPE=0

CHALLENGER_GAME_TYPES=cannon
CHALLENGER_NUM_CONFIRMATIONS=1
